<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_runners" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_pending"
            android:alpha="0.9"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvStatusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Pending Approval"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:text="Your registration has been submitted successfully!"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvStatusSubMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:text="Please wait for your coach to approve your account."
            android:textColor="@android:color/white"
            android:alpha="0.8"
            android:textSize="14sp"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Check Status"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:backgroundTint="@color/brand_blue"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_refresh"
            app:iconTint="@android:color/white"
            android:elevation="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Logout"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            app:icon="@drawable/ic_logout"
            app:iconTint="@android:color/white" />

    </LinearLayout>
</FrameLayout>